# SolGate Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (free tier works; enable anonymous sign-ins for wallet metadata auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Quicknode RPC (Solana)
VITE_QUICKNODE_RPC_URL=https://your-endpoint.quiknode.pro/xxxxx
VITE_QUICKNODE_WSS_URL=wss://your-endpoint.quiknode.pro/xxxxx

# DFlow Swap API (leave empty for dev endpoint)
VITE_DFLOW_API_KEY=

# LI.FI Cross-Chain Bridge
VITE_LIFI_INTEGRATOR=solgate

# Optional live marketing metrics endpoint.
# Kamino vault APY/TVL is pulled directly from https://api.kamino.finance and does not require an env key.
VITE_PLATFORM_METRICS_ENDPOINT=

# Palm USD public data
VITE_PALMUSD_API_BASE=https://api.palmusd.com

# GoldRush / Covalent route confidence
VITE_GOLDRUSH_API_KEY=
VITE_GOLDRUSH_API_BASE=https://api.covalenthq.com

# Cloak private treasury mode
VITE_CLOAK_RELAY_URL=https://api.cloak.ag
VITE_CLOAK_CIRCUITS_BASE_URL=https://cloak-circuits.s3.us-east-1.amazonaws.com/circuits/0.1.0

# Umbra private balance mode
VITE_UMBRA_NETWORK=devnet
VITE_UMBRA_INDEXER_API=https://utxo-indexer.api.umbraprivacy.com
VITE_UMBRA_RELAYER_API=https://relayer.api.umbraprivacy.com

# Local QVAC route reviewer
VITE_QVAC_REVIEWER_URL=http://127.0.0.1:8787
# Optional Node env when starting npm run qvac:reviewer:
# QVAC_REVIEWER_ENABLE_MODEL=true

# Jito MEV Protection (mainnet block-engine path)
VITE_JITO_BLOCK_ENGINE_URL=mainnet.block-engine.jito.wtf

# Network: devnet | mainnet-beta
VITE_NETWORK=devnet

# Mock data toggle (set to "false" for real API calls)
VITE_USE_MOCK_DATA=true
